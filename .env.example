# CommandDeck .env
# Copy to .env and fill in your values. Never commit .env to git.

# Required for agent.py — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional overrides
COMMANDDECK_URL=http://192.168.4.148:8090
POLL_INTERVAL=10

# Launcher: base URL where production apps are served (nginx on appserv1)
APP_SERVER_URL=http://192.168.4.148
